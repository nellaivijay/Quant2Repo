# Quant2Repo Environment Variables
# Copy this file to .env and fill in your values.
# Only one LLM provider API key is required.

# ── LLM Provider API Keys (set at least one) ────────────────────────────
# Google Gemini (recommended — 2M token context + vision + free tier)
GEMINI_API_KEY=

# OpenAI GPT-4o / o3
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Ollama (local, free — no key needed, just start `ollama serve`)
# Override the default Ollama server URL if not localhost:
# OLLAMA_HOST=http://localhost:11434

# ── Pipeline Configuration ───────────────────────────────────────────────
# Default provider: auto | gemini | openai | anthropic | ollama
# "auto" detects from available API keys
Q2R_PROVIDER=auto

# Override the default model for the selected provider
# Leave empty to use the provider's best available model
Q2R_MODEL=

# Default data source for market data: yfinance | fred
Q2R_DATA_SOURCE=yfinance

# Cache directory for pipeline results (content-addressed by PDF hash)
Q2R_CACHE_DIR=.q2r_cache

# Set to "true" for detailed console output
Q2R_VERBOSE=false

# ── Gateway Mode (set by Any2Repo-Gateway, not for manual use) ───────────
# JOB_ID=                    # Triggers gateway mode when set
# TENANT_ID=                 # Tenant who submitted the job
# PDF_URL=                   # URL of the research paper
# PDF_BASE64=                # Base64-encoded PDF (alternative to PDF_URL)
# PAPER_TEXT=                 # Raw paper text (alternative to PDF_URL)
# CATALOG_ID=                 # Strategy from built-in catalog (e.g. time-series-momentum)
# OUTPUT_DIR=                 # Output directory (default: /tmp/q2r-{JOB_ID})
# ENGINE_OPTIONS=             # JSON: {"mode":"agent","refine":true,...}
# CALLBACK_URL=               # URL to POST results on completion
